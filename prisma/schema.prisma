generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PapelUsuario {
  OPERADOR
  GESTOR
}

enum StatusEntrega {
  CRIADA
  EM_TRANSITO
  ENTREGUE
  CANCELADA
}

enum StatusMotorista {
  ATIVO
  INATIVO
}

model Usuario {
  id              Int            @id @default(autoincrement())
  nome            String
  email           String         @unique
  senha           String
  papel           PapelUsuario   @default(OPERADOR)
  entregasCriadas Entrega[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Motorista {
  id            Int               @id @default(autoincrement())
  nome          String
  cpf           String            @unique
  status        StatusMotorista   @default(ATIVO)
  placaVeiculo  String
  entregas      Entrega[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Entrega {
  id            Int               @id @default(autoincrement())
  descricao     String
  origem        String
  destino       String
  status        StatusEntrega     @default(CRIADA)
  
  motorista     Motorista?        @relation(fields: [motoristaId], references: [id])
  motoristaId   Int?
  
  criador       Usuario?          @relation(fields: [criadorId], references: [id])
  criadorId     Int?
  
  historico     EventoEntrega[]
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model EventoEntrega {
  id          Int       @id @default(autoincrement())
  descricao   String
  entrega     Entrega   @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  entregaId   Int
  createdAt   DateTime  @default(now())
}