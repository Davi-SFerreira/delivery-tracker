<% if (messages.sucesso) { %>
    <div style="color: #155724; background-color: #d4edda; border: 1px solid #c3e6cb; padding: 10px; margin-bottom: 15px;">
        <%= messages.sucesso %>
    </div>
<% } %>

<% if (messages.erro) { %>
    <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 10px; margin-bottom: 15px;">
        <%= messages.erro %>
    </div>
<% } %>