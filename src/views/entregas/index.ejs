<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Painel - Listagem de Entregas</title>
</head>
<body style="font-family: Arial, sans-serif; margin: 20px;">
    <%- include('../partials/nav') %>
    <%- include('../partials/flash') %>

    <h2>Entregas Cadastradas</h2>

    <form action="/painel/entregas" method="GET" style="margin-bottom: 20px;">
        <label>Filtrar por status:</label>
        <select name="status">
            <option value="">Todos</option>
            <option value="CRIADA">CRIADA</option>
            <option value="EM_TRANSITO">EM_TRANSITO</option>
            <option value="ENTREGUE">ENTREGUE</option>
            <option value="CANCELADA">CANCELADA</option>
        </select>
        <button type="submit">Filtrar</button>
    </form>

    <a href="/painel/entregas/nova">
        <button data-testid="btn-nova-entrega" style="margin-bottom: 15px;">+ Nova Entrega</button>
    </a>

    <table border="1" cellpadding="10" cellspacing="0" style="width: 100%; text-align: left;">
        <thead>
            <tr style="background-color: #eee;">
                <th>ID</th>
                <th>Descrição</th>
                <th>Origem</th>
                <th>Destino</th>
                <th>Status</th>
                <th>Data</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            <% entregas.forEach(entrega => { %>
                <tr>
                    <td><%= entrega.id %></td>
                    <td><%= entrega.descricao %></td>
                    <td><%= entrega.origem %></td>
                    <td><%= entrega.destino %></td>
                    <td><strong><%= entrega.status %></strong></td>
                    <td><%= new Date(entrega.createdAt).toLocaleDateString('pt-BR') %></td>
                    <td>
                        <a href="/painel/entregas/<%= entrega.id %>">Detalhes</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>